#!/bin/bash
# Setting up various environment variables

#
# Miscellaneous variables
#

# Set XDG dirs if not set
if [ -z "${XDG_CONFIG_HOME-}" ]; then
    export XDG_CONFIG_HOME="$HOME/.config"
fi

if [ -z "${XDG_CACHE_HOME-}" ]; then
    export XDG_CACHE_HOME="$HOME/.cache"
fi

if [ -z "${XDG_DATA_HOME-}" ]; then
    export XDG_DATA_HOME="$HOME/.local/share"
fi

if [ -z "${XDG_STATE_HOME-}" ]; then
    export XDG_STATE_HOME="$HOME/.local/state"
fi

# set OS
export OS={{ .chezmoi.os | quote }}
# export OS="$(uname -s | tr '[A-Z]' '[a-z]')"

# Color settings
# colored GCC warnings and errors
export GCC_COLORS='error=01;31:warning=01;35:note=01;36:caret=01;32:locus=01:quote=01'

# colored less
if [ -x "$HOME/bin/source-highlight-esc.sh" ]; then
    export LESSOPEN="| $HOME/bin/source-highlight-esc.sh %s"
elif [ -x "$HOME/.local/bin/source-highlight-esc.sh" ]; then
    export LESSOPEN="| $HOME/bin/source-highlight-esc.sh %s"
elif [ -x "/usr/bin/source-highlight-esc.sh" ]; then
    export LESSOPEN="| /usr/bin/source-highlight-esc.sh %s"
fi
export LESS='-R '
export LESS_TERMCAP_mb=$'\E[1;31m' # begin blink
export LESS_TERMCAP_md=$'\E[1;36m' # begin bold
export LESS_TERMCAP_me=$'\E[0m'    # reset bold/blink
#.export LESS_TERMCAP_so=$'\E[01;44;33m' # begin reverse video
export LESS_TERMCAP_se=$'\E[0m'    # reset reverse video
export LESS_TERMCAP_us=$'\E[1;32m' # begin underline
export LESS_TERMCAP_ue=$'\E[0m'    # reset underline

# ls settings
LS_COLORS='rs=0:di=01;34:ln=01;36:mh=00:pi=40;33:so=01;35:do=01;35:bd=40;33;01:cd=40;33;01:or=40;31;01:mi=00:su=37;41:sg=30;43:ca=30;41:tw=30;42:ow=0;44:st=37;44:ex=01;32:*.tar=01;31:*.tgz=01;31:*.arc=01;31:*.arj=01;31:*.taz=01;31:*.lha=01;31:*.lz4=01;31:*.lzh=01;31:*.lzma=01;31:*.tlz=01;31:*.txz=01;31:*.tzo=01;31:*.t7z=01;31:*.zip=01;31:*.z=01;31:*.dz=01;31:*.gz=01;31:*.lrz=01;31:*.lz=01;31:*.lzo=01;31:*.xz=01;31:*.zst=01;31:*.tzst=01;31:*.bz2=01;31:*.bz=01;31:*.tbz=01;31:*.tbz2=01;31:*.tz=01;31:*.deb=01;31:*.rpm=01;31:*.jar=01;31:*.war=01;31:*.ear=01;31:*.sar=01;31:*.rar=01;31:*.alz=01;31:*.ace=01;31:*.zoo=01;31:*.cpio=01;31:*.7z=01;31:*.rz=01;31:*.cab=01;31:*.wim=01;31:*.swm=01;31:*.dwm=01;31:*.esd=01;31:*.jpg=01;35:*.jpeg=01;35:*.mjpg=01;35:*.mjpeg=01;35:*.gif=01;35:*.bmp=01;35:*.pbm=01;35:*.pgm=01;35:*.ppm=01;35:*.tga=01;35:*.xbm=01;35:*.xpm=01;35:*.tif=01;35:*.tiff=01;35:*.png=01;35:*.svg=01;35:*.svgz=01;35:*.mng=01;35:*.pcx=01;35:*.mov=01;35:*.mpg=01;35:*.mpeg=01;35:*.m2v=01;35:*.mkv=01;35:*.webm=01;35:*.webp=01;35:*.ogm=01;35:*.mp4=01;35:*.m4v=01;35:*.mp4v=01;35:*.vob=01;35:*.qt=01;35:*.nuv=01;35:*.wmv=01;35:*.asf=01;35:*.rm=01;35:*.rmvb=01;35:*.flc=01;35:*.avi=01;35:*.fli=01;35:*.flv=01;35:*.gl=01;35:*.dl=01;35:*.xcf=01;35:*.xwd=01;35:*.yuv=01;35:*.cgm=01;35:*.emf=01;35:*.ogv=01;35:*.ogx=01;35:*.aac=00;36:*.au=00;36:*.flac=00;36:*.m4a=00;36:*.mid=00;36:*.midi=00;36:*.mka=00;36:*.mp3=00;36:*.mpc=00;36:*.ogg=00;36:*.ra=00;36:*.wav=00;36:*.oga=00;36:*.opus=00;36:*.spx=00;36:*.xspf=00;36:'
export LS_COLORS

# Set coloredlogs color formatting
export COLOREDLOGS_FIELD_STYLES='asctime=2;hostname=5;levelname=7,bold;name=4;programname=6;username=3'

# Adding CHROOT location environment variable
if [[ -d "$HOME/chroot" ]]; then
    export CHROOT="$HOME/chroot"
fi

# Setting JAVA_HOME environment variable
if [[ -d "/usr/lib/jvm/default-java" ]]; then
    export JAVA_HOME="/usr/lib/jvm/default-java"
fi

# Setting VOC directory path environment variable
if [[ -d "/usr/share/java/voc" ]]; then
    export VOC_DIR="/usr/share/java/voc"
fi

#
# Configuring PATH
#
# Store original system path
PATH_SYS="$PATH"
export PATH_SYS

# Source rust if it exists
[[ -s "$HOME/.cargo/env" ]] && source "$HOME/.cargo/env"

# Source deno if it exists
[[ -s "$HOME/.deno/env" ]] && source "$HOME/.deno/env"

# bun
if [[ -d "$HOME/.bun" ]]; then
    export BUN_INSTALL="$HOME/.bun"
    PATH="$BUN_INSTALL/bin:$PATH"
fi

# Setting ANDROID_HOME environment variable
if [[ -d "$HOME/Android/Sdk" ]]; then
    export ANDROID_HOME="$HOME/Android/Sdk"
    # Adding android sdk paths to PATH
    PATH="$PATH:$ANDROID_HOME/tools"
fi

# Adding ccache binaries to PATH
if [[ -d /usr/lib/ccache/bin ]]; then
    PATH="/usr/lib/ccache/bin/:$PATH"
fi

if [[ -d "$HOME/perl5/bin" ]]; then
    # PATH="${PATH:+:${PATH}}:$HOME/perl5/bin"
    PATH="$PATH:$HOME/perl5/bin"
    export PERL5LIB="$HOME/perl5/lib/perl5${PERL5LIB:+:${PERL5LIB}}"
    export PERL_LOCAL_LIB_ROOT="$HOME/perl5${PERL_LOCAL_LIB_ROOT:+:${PERL_LOCAL_LIB_ROOT}}"
    export PERL_MB_OPT="--install_base \"$HOME/perl5\""
    export PERL_MM_OPT="INSTALL_BASE=$HOME/perl5"
fi

if [[ -d "$HOME/go/bin" ]]; then
    PATH="$HOME/go/bin:$PATH"
fi

if [[ -d "$HOME/.config/nvm" ]]; then
    export NVM_DIR="$HOME/.config/nvm"
    [ -s "$NVM_DIR/nvm.sh" ] && source "$NVM_DIR/nvm.sh"                   # This loads nvm
    [ -s "$NVM_DIR/bash_completion" ] && source "$NVM_DIR/bash_completion" # This loads nvm bash_completion
fi

if [[ -d "$HOME/.yarn/bin" ]]; then
    PATH="$HOME/.yarn/bin:$PATH"
fi

# Adding ruby libraries and binaries to PATH
if [[ $(command -v 'ruby') ]]; then
    gem_bin_dir="$(ruby -e 'print Gem.user_dir')/bin"
    mkdir -p "$gem_bin_dir"
    PATH="$gem_bin_dir:$PATH"
fi

# Adding intel compilers and libraries to PATH
if [[ -d /opt/intel/bin ]]; then
    PATH="$PATH:/opt/intel/bin"
fi

# Adding linuxbrew libraries and binaries to PATH
if [[ -d /home/linuxbrew && $(command -v 'linuxbrew') ]]; then
    PATH="$PATH:/home/linuxbrew/.linuxbrew/bin:/home/linuxbrew/.linuxbrew/sbin"
fi

if [[ -d "$HOME/.ghcup/bin" ]]; then
    PATH="$PATH:$HOME/.ghcup/bin"
fi

# Adding neovim syntax checking libraries to PATH
# PATH="$PATH:/usr/share/nvim/runtime/syntax_checkers/swift:$HOME/.cache/dein/repos/github.com/kballard/vim-swift/syntax_checkers/swift"

#if [[ -d /opt/depot_tools ]]; then
#  PATH="${PATH}:/opt/depot_tools"
#fi

if [[ -d "$HOME/.luarocks/bin" ]]; then
    PATH="$HOME/.luarocks/bin:$PATH"
fi

# Setting up lua path for neovim
if [[ $(command -v "luarocks") ]]; then
    eval "$(luarocks path --no-bin --lua-version 5.1)"
fi

# Composer
[[ -d "$HOME/.config/composer/vendor/bin" ]] && PATH="$HOME/.config/composer/vendor/bin:$PATH"

# Set up final PATH dirs that should overwrite everything else
# Adding user bin and bin/bin directory to PATH
[[ -d "$HOME/bin/bin" ]] && PATH="$HOME/bin:$HOME/bin/bin:$PATH"

# Adding ~/.local/bin
[[ -d "$HOME/.local/bin" ]] && PATH="$HOME/.local/bin:$PATH"

# Deduplicate PATH
PATH=$(deduplicate_path "$PATH")

# echo $PATH
# PATH
# PATH_WINDOWS
# PATH_FULL
PATH_CLEAN=""
PATH_WINDOWS=""
# PATH_FULL=""

if [[ -z "${MANPATH}" ]]; then
    MANPATH=$(man --path)
fi
# Exclude windows man paths as it makes man very slow
export MANPATH="$(remove_windows_paths "$MANPATH")"

# Configure python paths
if has_command python3; then
    export PYTHON3_HOST_PROG="$(command -v python3)"
elif has_command python && command python --version 2>/dev/null | grep -q -Pe '.*\b3\.\d+'; then
    export PYTHON3_HOST_PROG="$(command -v python)"
fi

{{ if .os.is_wsl -}}
# WSL Specific
export WINHOME={{ (index .secrets.system .system.hostname).wsl_winhome | quote }}

export GTK_THEME="Adwaita:dark"
# Use Windows Browser
export BROWSER={{ (index .secrets.system .system.hostname).browser | quote }}

# Split path into linux and windows parts
OLDIFS=$IFS
IFS=':'
for p in $PATH; do
    if [[ "$p" == "/mnt/"* ]]; then
        # Append to Windows path
        PATH_WINDOWS="$PATH_WINDOWS:$p"
    else
        # Append to Clean path
        PATH_CLEAN="$PATH_CLEAN:$p"
    fi
done
IFS=$OLDIFS

PATH_CLEAN="${PATH_CLEAN:1}"
PATH_WINDOWS="${PATH_WINDOWS:1}"

# export PATH_NO_WINDOWS="$(/usr/bin/printenv PATH | /usr/bin/perl -ne 'print join(":", grep { !/\/mnt\/[a-z]/ } split(/:/));' | awk -vRS=: '!a[$0]++' | paste -s -d:)"
# export PATH_CLEAN="$(remove_windows_paths "$PATH")"
export PATH_CLEAN
export PATH_WINDOWS

PATH="$PATH_CLEAN"
export PATH_SYS_CLEAN="$(remove_windows_paths "$PATH_SYS")"
# export PATH_FULL="$PATH_CLEAN:$PATH_WINDOWS"

# Remove windows paths from path
# manpager_path="$(/usr/bin/printenv PATH | /usr/bin/perl -ne 'print join(":", grep { !/\/mnt\/[a-z]/ } split(/:/));' | awk -vRS=: '!a[$0]++' | paste -s -d:)"
{{- else -}}
# else
export PATH_CLEAN="$PATH"
export PATH_SYS_CLEAN="$PATH_SYS"
export PATH_WINDOWS
# export PATH_FULL="$"
{{- end }}

export PATH

# check if neovim is installed, if it is set it as the default editor
# and oni as the default visual editor if neovim is not available,
# nano gets set as the default text editor
EDITOR=""
if has_command nvim; then
    EDITOR=$(command -v nvim)

    # Set up manpager
    export MANWIDTH=999
{{- if .os.is_wsl }}
    # use cleaned path on WSL
    export MANPAGER="env PATH='$PATH_CLEAN' nvim +Man!"
{{- else }}
    export MANPAGER='nvim +Man!'
{{- end }}
elif has_command nano; then
    EDITOR="$(command -v nano)"
fi
export EDITOR

export SUDO_EDITOR="$EDITOR"

VISUAL=""
if has_command zed; then
    VISUAL="$(command -v zed)"
elif has_command code; then
    VISUAL="$(command -v code)"
fi
export VISUAL

{{ if (and (.system.is_personal) (.secrets.api_keys.AVANTE_GEMINI_API_KEY)) -}}
# API keys
export AVANTE_GEMINI_API_KEY={{ .secrets.api_keys.AVANTE_GEMINI_API_KEY | quote }}
{{- end -}}
