# Composer
[[ -d "$HOME/.config/composer/vendor/bin" ]] && PATH="$HOME/.config/composer/vendor/bin:$PATH"

# Set up final PATH dirs that should overwrite everything else
# {{- if stat (joinPath .chezmoi.homeDir "bin/bin") }}
# Adding user bin and bin/bin directory to PATH
# [[ -d "$HOME/bin/bin" ]] &&
PATH="$HOME/bin:$HOME/bin/bin:$PATH"
# {{- end }}

# Adding ~/.local/bin
[[ -d "$HOME/.local/bin" ]] && PATH="$HOME/.local/bin:$PATH"


# {{- if .is_macos }}

# Add brew ruby binaries to path
if [[ -d '/usr/local/opt/ruby/bin' ]]; then
    PATH="/usr/local/opt/ruby/bin:$PATH"
fi

# Put GNU binaries before macOS binaries
if [[ -d "/usr/local/lib/gnubin" ]]; then
    PATH="/usr/local/lib/gnubin:$PATH"
fi

if [[ -d "/usr/local/opt/make/libexec/gnubin" ]]; then
    PATH="/usr/local/opt/make/libexec/gnubin:$PATH"
fi

if [[ -d "/usr/local/opt/uutils-coreutils/libexec/uubin" ]]; then
    PATH="/usr/local/opt/uutils-coreutils/libexec/uubin:$PATH"
fi

# Add perlbrew to PATH
if [[ -d "$HOME/perl5/perlbrew/bin" ]]; then
    PATH="$PATH:$HOME/perl5/perlbrew/bin"
fi

# Homebrew keg only packages
if [[ -d "/usr/local/opt/binutils/bin" ]]; then
    PATH="$PATH:/usr/local/opt/binutils/bin"
fi

# Add llvm to PATH
if [[ -d "/usr/local/opt/llvm/bin" ]]; then
    PATH="$PATH:/usr/local/opt/llvm/bin"
fi

# Add Qt to PATH
if [[ -d "/usr/local/opt/qt/bin" ]]; then
    PATH="$PATH:/usr/local/opt/qt/bin"
fi

# Add mactex binaries to PATH
if [[ -d "/Library/TeX/Root/bin/universal-darwin" ]]; then
    PATH="$PATH:/Library/TeX/Root/bin/universal-darwin"
fi
# {{- end }}

# Deduplicate PATH
PATH=$(deduplicate_path "$PATH")

# echo $PATH
# PATH
# PATH_WINDOWS
# PATH_FULL
PATH_CLEAN=""
PATH_WINDOWS=""
# PATH_FULL=""
# export PATH_SAVE="$PATH"

if [[ -z "${MANPATH}" ]]; then
    MANPATH=$(man --path)
fi

# Configure python paths
if has_command python3; then
    export PYTHON3_HOST_PROG="$(command -v python3)"
elif has_command python && command python --version 2>/dev/null | grep -q -Pe '.*\b3\.\d+'; then
    export PYTHON3_HOST_PROG="$(command -v python)"
fi

# {{- if .is_wsl }}

# Exclude windows man paths as it makes man very slow
export MANPATH="$(remove_windows_paths "$MANPATH")"

# WSL Specific
export WINHOME=# {{ (index .secrets.system .system.hostname).wsl_winhome | quote }}

# Use Windows Browser
export BROWSER=# {{ (index .secrets.system .system.hostname).browser | quote }}

# Split path into linux and windows parts
OLDIFS=$IFS
IFS=':'
for p in $PATH; do
    if [[ "$p" == "/mnt/"* ]]; then
        # Append to Windows path
        PATH_WINDOWS="$PATH_WINDOWS:$p"
    else
        # Append to Clean path
        PATH_CLEAN="$PATH_CLEAN:$p"
    fi
done
IFS=$OLDIFS

PATH_CLEAN="${PATH_CLEAN:1}"
PATH_WINDOWS="${PATH_WINDOWS:1}"

# export PATH_NO_WINDOWS="$(/usr/bin/printenv PATH | /usr/bin/perl -ne 'print join(":", grep { !/\/mnt\/[a-z]/ } split(/:/));' | awk -vRS=: '!a[$0]++' | paste -s -d:)"
# export PATH_CLEAN="$(remove_windows_paths "$PATH")"
export PATH_CLEAN
export PATH_WINDOWS

# PATH="$PATH_CLEAN"
export PATH_SYS_CLEAN="$(remove_windows_paths "$PATH_SYS")"
# export PATH_FULL="$PATH_CLEAN:$PATH_WINDOWS"

# Remove windows paths from path
# manpager_path="$(/usr/bin/printenv PATH | /usr/bin/perl -ne 'print join(":", grep { !/\/mnt\/[a-z]/ } split(/:/));' | awk -vRS=: '!a[$0]++' | paste -s -d:)"
# {{- else -}}
# else
export PATH_CLEAN="$PATH"
export PATH_SYS_CLEAN="$PATH_SYS"
export PATH_WINDOWS
