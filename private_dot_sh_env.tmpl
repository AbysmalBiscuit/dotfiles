# Set coloredlogs color formatting
export COLOREDLOGS_FIELD_STYLES='asctime=2;hostname=5;levelname=7,bold;name=4;programname=6;username=3'

# Adding CHROOT location environment variable
if [[ -d "$HOME/chroot" ]]; then
    export CHROOT="$HOME/chroot"
fi

# {{ if .is_macos -}}
# Setting darwin only environment variables
# Add /usr/local/bin to PATH (needed to find brew installed binaries)
if [[ -d "/usr/local/bin" ]]; then
    PATH="/usr/local/bin:$PATH"
fi

# Setting JAVA_HOME environment variable
export JAVA_HOME="$(/usr/libexec/java_home -v 24)"

# {{ else if .is_linux -}}
# {{ if stat "/usr/lib/jvm/default-java"  -}}
# Setting JAVA_HOME environment variable
# if [[ -d "/usr/lib/jvm/default-java" ]]; then
    export JAVA_HOME="/usr/lib/jvm/default-java"
# fi
# {{- end }}
# {{- end }}

# Setting VOC directory path environment variable
# {{ if stat "/usr/share/java/voc" -}}
# if [[ -d "/usr/share/java/voc" ]]; then
export VOC_DIR="/usr/share/java/voc"
# fi
# {{- end }}

export GTK_THEME="Adwaita:dark"

# Configuring rust programs
export CLIPPY_CONF_DIR="$HOME/.config/clippy"
export EZA_CONFIG_DIR="$HOME/.config/eza"

# {{- if stat "/opt/intel" }}
# Adding various Intel variables
# if [[ -d "/opt/intel" ]]; then
export TBBROOT="/opt/intel/tbb"
export PSTLROOT="/opt/intel/pstl"
export DAALROOT="/opt/intel/daal"
export PKG_CONFIG_PATH="/opt/intel/mkl/bin/pkgconfig"
export TBB_PATH="/opt/intel/tbb"
export MANPATH="/opt/intel/man/common:/opt/intel/documentation_2020/en/debugger/gdb-ia/man/:$MANPATH"
export DYLD_LIBRARY_PATH="/opt/intel/lib:/opt/intel/lib/intel64:/opt/intel/ipp/lib:/opt/intel/mkl/lib:/opt/intel/tbb/lib:/opt/intel/daal/lib:$DYLD_LIBRARY_PATH"
export INFOPATH="/opt/intel/documentation_2020/en/debugger/gdb-ia/info/:$INFOPATH"
export IPPROOT="/opt/intel/ipp"
export LIBRARY_PATH="/opt/intel/ipp/lib:/opt/intel/lib:/opt/intel/mkl/lib:/opt/intel/tbb/lib:/opt/intel/tbb/lib:/opt/intel/daal/lib:$LIBRARY_PATH"
export CLASSPATH="/opt/intel/daal/lib/daal.jar:$CLASSPATH"
export MKLROOT="/opt/intel/mkl"
export NLSPATH="/opt/intel/lib/locale/en_US/%N:/opt/intel/mkl/lib/locale/%l_%t/%N:/opt/intel/debugger_2020/gdb/intel64/share/locale/%l_%t/%N:$NLSPATH"
# PATH=/opt/intel/bin:/usr/local/lib/gnubin:/usr/local/opt/python/libexec/bin:/Users/admin/bin:/Users/admin/bin/bin:/usr/local/bin:/usr/bin:/bin:/usr/local/sbin:/Users/admin/.gem/ruby/2.6.0/bin:/opt/intel/bin:/Users/admin/.cache/dein/repos/github.com/kballard/vim-swift/syntax_checkers/swift:/usr/sbin:/sbin:/Library/TeX/texbin:/usr/local/MacGPG2/bin:/Library/Apple/usr/bin:/Library/Frameworks/Mono.framework/Versions/Current/Commands:/Applications/Wireshark.app/Contents/MacOS
export INTEL_PYTHONHOME="/opt/intel/debugger_2020/python/intel64/"
export INTEL_LICENSE_FILE="/opt/intel/licenses:/Users/admin/intel/licenses:/Users/Shared/Library/Application Support/Intel/Licenses"
export CPATH="/opt/intel/ipp/include:/opt/intel/mkl/include:/opt/intel/pstl/include:/opt/intel/pstl/stdlib:/opt/intel/tbb/include:/opt/intel/tbb/include:/opt/intel/daal/include:$CPATH"
PATH="$PATH:/opt/intel/bin"
# fi
# {{- end }}

# Add tesseract data
# {{ if stat (joinPath .chezmoi.homeDir "tessdata") -}}
# if [[ -d "$HOME/tessdata" ]]; then
export TESSDATA_PREFIX="$HOME/tessdata"
# fi
# {{- end }}

if has_command mold; then
    export MOLD="$(command -v mold)"
fi

#
# Configuring PATH
#
# Store original system path
# {{ if .is_macos -}}
if [[ -x /usr/libexec/path_helper ]]; then
    PATH_SYS="$(/usr/libexec/path_helper)"
else
    PATH_SYS="$PATH"
fi

# Add /usr/local/sbin to PATH
if [[ -d "/usr/local/sbin" ]]; then
    PATH="$PATH:/usr/local/sbin"
fi
# {{- else -}}
PATH_SYS="$PATH"
# {{- end }}
export PATH_SYS

# Source rust if it exists
[[ -s "$HOME/.cargo/env" ]] && source "$HOME/.cargo/env"

# Source deno if it exists
[[ -s "$HOME/.deno/env" ]] && source "$HOME/.deno/env"

# bun
if [[ -d "$HOME/.bun" ]]; then
    export BUN_INSTALL="$HOME/.bun"
    PATH="$BUN_INSTALL/bin:$PATH"
fi

# Setting ANDROID_HOME environment variable
if [[ -d "$HOME/Android/Sdk" ]]; then
    export ANDROID_HOME="$HOME/Android/Sdk"
    # Adding android sdk paths to PATH
    PATH="$PATH:$ANDROID_HOME/tools"
fi

# Adding ccache binaries to PATH
# if [[ -d /usr/lib/ccache/bin ]]; then
    # PATH="/usr/lib/ccache/bin/:$PATH"
# fi

if [[ -d "$HOME/perl5/bin" ]]; then
    # PATH="${PATH:+:${PATH}}:$HOME/perl5/bin"
    PATH="$PATH:$HOME/perl5/bin"
    export PERL5LIB="$HOME/perl5/lib/perl5${PERL5LIB:+:${PERL5LIB}}"
    export PERL_LOCAL_LIB_ROOT="$HOME/perl5${PERL_LOCAL_LIB_ROOT:+:${PERL_LOCAL_LIB_ROOT}}"
    export PERL_MB_OPT="--install_base \"$HOME/perl5\""
    export PERL_MM_OPT="INSTALL_BASE=$HOME/perl5"
fi

if [[ -d "$HOME/go/bin" ]]; then
    PATH="$HOME/go/bin:$PATH"
fi

if [[ -d "$HOME/.config/nvm" ]]; then
    export NVM_DIR="$HOME/.config/nvm"
    [[ -s "$NVM_DIR/nvm.sh" ]] && source "$NVM_DIR/nvm.sh"                   # This loads nvm
    [[ -s "$NVM_DIR/bash_completion" ]] && source "$NVM_DIR/bash_completion" # This loads nvm bash_completion
fi

if [[ -d "$HOME/.yarn/bin" ]]; then
    PATH="$HOME/.yarn/bin:$PATH"
fi

# Adding ruby libraries and binaries to PATH
if has_command ruby; then
    gem_bin_dir="$(ruby -e 'print Gem.user_dir')/bin"
    mkdir -p "$gem_bin_dir"
    PATH="$gem_bin_dir:$PATH"
fi

# {{- if and .has.brew (stat "/home/linuxbrew/.linuxbrew") }}

# Adding linuxbrew libraries and binaries to PATH
# if [[ -d /home/linuxbrew && $(command -v 'linuxbrew') ]]; then
PATH="$PATH:/home/linuxbrew/.linuxbrew/bin:/home/linuxbrew/.linuxbrew/sbin"
# fi
