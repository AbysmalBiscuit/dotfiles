# check if neovim is installed, if it is set it as the default editor
# and oni as the default visual editor if neovim is not available,
# nano gets set as the default text editor
EDITOR=""
if has_command nvim; then
    EDITOR=$(command -v nvim)

    # Set up manpager
    export MANWIDTH=999
# {{- if .is_wsl }}
    # use cleaned path on WSL
    export MANPAGER="env PATH='$PATH_CLEAN' nvim +Man!"
# {{- else }}
    export MANPAGER='nvim +Man!'
# {{- end }}
elif has_command nano; then
    EDITOR="$(command -v nano)"
fi
export EDITOR

export SUDO_EDITOR="$EDITOR"

VISUAL=""
if has_command zed; then
    VISUAL="$(command -v zed)"
elif has_command code; then
    VISUAL="$(command -v code)"
fi
export VISUAL

# {{ if (and (.is_personal) (.secrets.api_keys.avante.personal.gemini)) -}}
# API keys
export AVANTE_GEMINI_API_KEY=# {{ .secrets.api_keys.avante.personal.gemini | quote }}
