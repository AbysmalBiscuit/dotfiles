# elif [[ -x "$HOME/.local/bin/source-highlight-esc.sh" ]]; then
export LESSOPEN="| $HOME/.local/bin/source-highlight-esc.sh %s"
# {{ else if stat (joinPath "/usr/bin/source-highlight-esc.sh") -}}
# elif [[ -x "/usr/bin/source-highlight-esc.sh" ]]; then
export LESSOPEN="| /usr/bin/source-highlight-esc.sh %s"
