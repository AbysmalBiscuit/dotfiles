export MANPATH='# {{ $man_path }}'

# check if neovim is installed, if it is set it as the default editor
# and oni as the default visual editor if neovim is not available,
# nano gets set as the default text editor
EDITOR=""
# {{ if .tool.neovim -}}
# EDITOR=$(command -v nvim)
# {{- $local_nvim := joinPath .chezmoi.homeDir ".local" "bin" "nvim" | default (lookPath "nvim") }}
EDITOR='# {{ $local_nvim }}'
export NVIM_EXECUTABLE='# {{ $local_nvim }}'
export _EDITOR="$EDITOR"

# Set up manpager
export MANWIDTH=999
# {{- if .is_wsl }}
# use cleaned path on WSL
export MANPAGER="env PATH='$PATH_CLEAN' nvim +Man!"
# {{- else }}
export MANPAGER='nvim +Man!'
# {{- end }}
# {{- else if .tool.nano -}}
EDITOR='# {{ .tool.nano }}'

# {{- end }}
export EDITOR

export SUDO_EDITOR="$EDITOR"

# {{- if index .has "zed" }}
VISUAL="# {{ .tool.zed }}"
# {{- else if index .has "code" -}}
VISUAL="# {{ .tool.code }}"
# {{- else -}}
VISUAL=""
# {{- end }}
export VISUAL

# {{ if (and (.is_personal) (.secrets.api_keys.avante.personal.gemini)) -}}
