# {{- if .has.bash }}
{
    echo
    curl -sL 'https://raw.githubusercontent.com/oven-sh/bun/refs/heads/main/completions/bun.bash'
    echo
} >>'# {{ $comp_file.bash }}'
# {{- end }}

# {{- if .has.fish }}
{
    echo
    curl -sL 'https://raw.githubusercontent.com/oven-sh/bun/refs/heads/main/completions/bun.fish'
    echo
} >>'# {{ $comp_file.fish }}'

# {{- end }}

