#!/usr/bin/env pwsh
# chezmoi:template:left-delimiter="# {{" right-delimiter="}}"
# {{ if false -}}
# vim:filetype=ps1.chezmoitmpl
# {{- end -}}
# {{- $bin_dir := joinPath .chezmoi.homeDir ".local" "bin" -}}
# {{- $arch := "" -}}
# {{- $asset := "" -}}
# {{- if eq .chezmoi.arch "arm64" -}}
# {{- $arch = "arm64" }}
# {{- $asset = "nvim-win-arm64" -}}
# {{- else -}}
# {{- $arch = "x86_64" -}}
# {{- $asset = "nvim-win64" -}}
# {{- end -}}
# {{- $zip_file := joinPath $bin_dir (printf "%s.zip" $asset) -}}
# {{- $nvim_bin := joinPath $bin_dir $asset "bin" "nvim.exe" -}}
# {{- $link_path := joinPath $bin_dir "nvim.cmd" -}}
# {{ "" }}
# Updates neovim from GitHub releases (tar.gz)
# # {{ gitHubLatestRelease "neovim/neovim" | toJson | sha256sum }}

Set-StrictMode -Version Latest
$ErrorActionPreference = 'Stop'

$CacheFile = "# {{ joinPath .chezmoi.homeDir ".config" "chezmoi" "nvim_install" }}"
$Now = [DateTimeOffset]::UtcNow.ToUnixTimeSeconds()
if (Test-Path $CacheFile) {
    $LastCache = [long](Get-Content $CacheFile -Raw).Trim()
    if (($Now - $LastCache) -lt (86400 * 3)) {
        exit 0
    }
}

$BinDir = "# {{ joinPath .chezmoi.homeDir ".local" "bin" }}"
$Arch = "# {{ $arch }}"
$Asset = "# {{ $asset }}.zip"
$ExtractDir = "# {{ joinPath $bin_dir $asset }}"

$Url = "https://github.com/neovim/neovim/releases/download/nightly/# {{ $asset }}.zip"

New-Item -ItemType Directory -Force -Path $BinDir | Out-Null

# Fetch checksum from GitHub API
$Release = Invoke-RestMethod -Uri 'https://api.github.com/repos/neovim/neovim/releases/tags/nightly'
$AssetInfo = $Release.assets | Where-Object { $_.name -eq $Asset } | Select-Object -First 1
$Checksum = if ($AssetInfo) { $AssetInfo.digest -replace '^sha256:', '' } else { $null }

Write-Host "Downloading $Asset..."
Invoke-WebRequest -Uri $Url -OutFile '# {{ $zip_file }}'

if ($Checksum) {
    Write-Host "Verifying checksum..."
    $Actual = (Get-FileHash -Algorithm SHA256 '# {{ $zip_file }}').Hash.ToLower()
    if ($Checksum -ne $Actual) {
        Write-Error "Checksum mismatch!`n  Expected: $Checksum`n  Got:      $Actual"
        Remove-Item '# {{ $zip_file }}' -Force
        exit 1
    }
    Write-Host "Checksums match."
} else {
    Write-Warning "No checksum found, proceeding anyway."
}

# Extract
if (Test-Path $ExtractDir) { Remove-Item $ExtractDir -Recurse -Force }
Expand-Archive -Path '# {{ $zip_file }}' -DestinationPath $BinDir -Force
Remove-Item '# {{ $zip_file }}'

# Link
if (Test-Path '# {{ $link_path }}') { Remove-Item '# {{ $link_path }}' -Force }
Set-Content -Path '# {{ $link_path }}' -Value "@`"# {{ $nvim_bin }}`" %*"

Write-Host "Neovim installed: $(& '# {{ $link_path }}' --version | Select-Object -First 1)"

New-Item -ItemType Directory -Force -Path (Split-Path $CacheFile) | Out-Null
Set-Content -Path $CacheFile -Value $Now -NoNewline
