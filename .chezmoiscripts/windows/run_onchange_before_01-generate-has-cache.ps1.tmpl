# chezmoi:template:left-delimiter="# {{" right-delimiter="}}"
# {{ if false -}}
# vim:filetype=ps1.chezmoitmpl
# {{- end }}
# {{- $cli_tools := list -}}
# {{- range $tool := .tools -}}
# {{- range $cmd := $tool.cmds -}}
# {{- $cli_tools = append $cli_tools $cmd -}}
# {{- end -}}
# {{- end -}}
# {{- $cli_tools = $cli_tools | sortAlpha | uniq }}

$hasToml = "# {{ joinPath .chezmoi.homeDir ".config" "chezmoi" "has.toml" }}"
$hasToolToml = "# {{ joinPath .chezmoi.homeDir ".config" "chezmoi" "has_tool.toml" }}"
$allCmds = [System.Collections.Generic.HashSet[string]]::new([System.StringComparer]::OrdinalIgnoreCase)
$pathDirs = $env:PATH -split [System.IO.Path]::PathSeparator
$pathExts = $env:PATHEXT -split ';'

foreach ($dir in $pathDirs) {
    if (-not $dir -or -not (Test-Path -LiteralPath $dir)) { continue }
    try {
        foreach ($file in [System.IO.Directory]::EnumerateFiles($dir)) {
            $ext = [System.IO.Path]::GetExtension($file)
            if ($pathExts -contains $ext) {
                [void]$allCmds.Add([System.IO.Path]::GetFileName($file))
                [void]$allCmds.Add([System.IO.Path]::GetFileNameWithoutExtension($file))
            }
        }
    } catch { }
}

# per-cmd entries
$lines = @(
# {{ range $cli_tools -}}
    "# {{ . | replaceAllRegex "[-.]" "_" }} = $(if ($allCmds.Contains('# {{ . }}')) { 'true' } else { 'false' })"
# {{ end -}}
)
$lines | Set-Content $hasToml

# tool-level (matched cmd or empty)
$toolLines = @(
# {{ range $tool := .tools -}}
# {{- $safe_name := $tool.name | replaceAllRegex "[-. ]" "_" | lower -}}
# {{- $cmds := $tool.cmds -}}
# {{- $first_cmd := index $cmds 0 -}}
    "# {{ $safe_name }} = ""$(
# {{- range $i, $cmd := $cmds -}}
# {{ if $i }} else# {{ end }}if ($allCmds.Contains('# {{ $cmd }}')) { '# {{ $cmd }}' }
# {{- end }} else { '' }
    )"""
# {{ end -}}
)
$toolLines | Set-Content $hasToolToml

