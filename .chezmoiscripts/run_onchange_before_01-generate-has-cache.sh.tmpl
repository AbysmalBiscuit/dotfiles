# {{- end -}}

# {{- $cli_tools := list -}}
# {{- $cli_tools_wsl := list -}}
# {{- range $tool := .tools -}}
# {{- range $cmd := $tool.cmds -}}
# {{- $cli_tools = append $cli_tools $cmd -}}
# {{- end -}}
# {{- end -}}
# {{ if $is_wsl -}}
# {{ "" }}
# {{- range $tool := .wsl_tools -}}
# {{- range $cmd := $tool.cmds -}}
# {{- $key := $cmd -}}
# {{- $cli_tools_wsl = append $cli_tools_wsl $key -}}
# {{- end -}}
# {{- end -}}
# {{- $cli_tools_wsl = $cli_tools_wsl | sortAlpha | uniq }}

OLD_PATH="$PATH"
if [ -n "$PATH_CLEAN" ]; then
    export PATH="$PATH_CLEAN"
fi
# {{- end }}
# {{- $cli_tools = $cli_tools | sortAlpha | uniq }}

SED=$(command -v "sed")
GREP=$(command -v "grep")
HAS_FILE="# {{ joinPath .chezmoi.homeDir ".config" "chezmoi" "has.toml" }}"
HAS_TOOL_FILE="# {{ joinPath .chezmoi.homeDir ".config" "chezmoi" "has_tool.toml" }}"

# per-cmd entries
{
    # {{ range $cli_tools -}}
    echo "# {{ . | replaceAllRegex "[-. ]" "_" }} = $(command -v "# {{ . }}" >/dev/null 2>&1 && echo true || echo false)"
    # {{ end }}
} >"$HAS_FILE"

# {{ if $is_wsl -}}
if [ -n "$PATH_WINDOWS" ]; then
    export PATH="$PATH_WINDOWS"
fi

wsl_tools=""
PWSH=$(command -v "pwsh.exe" 2>/dev/null || command -v "powershell.exe" 2>/dev/null)
if [ -n "$PWSH" ]; then
    wsl_tools="$("$PWSH" -NoProfile -NonInteractive -Command '
    $found = @{}
    $tools = @(
# {{ range $cli_tools_wsl -}}
        "# {{ . }}"
# {{ end -}}
    )
    Get-Command $tools -ErrorAction SilentlyContinue | ForEach-Object {
        $found[$_.Name] = $true
        $found[[System.IO.Path]::GetFileNameWithoutExtension($_.Name)] = $true
    }
# {{ range $cli_tools_wsl -}}
    "# {{ . | replaceAllRegex "[-. ]" "_" }} $(if ($found.ContainsKey("# {{ . }}")) { "true" } else { "false" })"
# {{ end -}}
' | "$SED" 's/\r//g')"
else
    wsl_tools="$({
        # {{ range $cli_tools_wsl -}}
        echo "# {{ . | replaceAllRegex "[-. ]" "_" }} $(command -v "# {{ . }}" >/dev/null 2>&1 && echo true || echo false)"
        # {{ end }}
    })"
fi
while IFS=' ' read -r key val; do
    if [ "$val" = "true" ]; then
        if "$GREP" -q "^${key} = " "$HAS_FILE"; then
            "$SED" -i "s/^${key} = false$/${key} = true/" "$HAS_FILE"
        else
            echo "$key = true" >>"$HAS_FILE"
        fi
    else
        echo "$key = $val" >>"$HAS_FILE"
    fi
done <<EOF
$wsl_tools
EOF
export PATH="$OLD_PATH"
# {{- end }}

# tool-level (matched cmd or empty)
echo >"$HAS_TOOL_FILE"
{
    # {{ range $tool := .tools -}}
    # {{- $safe_name := $tool.name | replaceAllRegex "[-. ]" "_" | lower -}}
    _tool_cmd=""
    # {{ range $cmd := $tool.cmds -}}
    [ -z "$_tool_cmd" ] && "$GREP" -q '^# {{ $cmd | replaceAllRegex "[-. ]" "_" }} = true$' "$HAS_FILE" && _tool_cmd="# {{ $cmd }}"
    # {{ end -}}
    echo '# {{ $safe_name }} = "'"$_tool_cmd"'"'
    # {{ end }}
    # {{ if $is_wsl -}}
    # {{ range $tool := .wsl_tools -}}
    # {{- $safe_name := printf "%s_exe" ($tool.name | replaceAllRegex "[-. ]" "_" | lower) -}}
    _tool_cmd=""
    # {{ range $cmd := $tool.cmds -}}
    [ -z "$_tool_cmd" ] && "$GREP" -q '^# {{ $cmd | replaceAllRegex "[-. ]" "_" | lower }} = true$' "$HAS_FILE" && _tool_cmd="# {{ $cmd }}"
    # {{ end -}}
    echo '# {{ $safe_name }} = "'"$_tool_cmd"'"'
    # {{ end -}}
    # {{- end }}
} >"$HAS_TOOL_FILE"
