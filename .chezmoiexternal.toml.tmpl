{{- if not .is_ephemeral -}}
{{- $asset := "" -}}
{{- $exe := "" -}}
{{- $compiler_os_alt := .compiler_os -}}
{{- if .is_linux -}}
{{- $compiler_os_alt = .compiler_os | replaceAllRegex "^pc" "unknown" -}}
{{- end -}}

