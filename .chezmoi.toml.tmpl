{{- if false -}}
# vim:filetype=chezmoi_toml.toml.chezmoitmpl
{{- end -}}
{{- /* System information */ -}}
{{- $is_work := false -}}{{/* true if this machine is a is_work machine */}}
{{- $is_personal := false -}}{{/* true if this machine should have personal secrets */}}
{{- $is_ephemeral := false -}}{{/* true if this machine is is_ephemeral, e.g. a cloud or VM instance */}}
{{- $is_headless := false -}}{{/* true if this machine does not have a screen and keyboard */}}
{{- $arch := "" }}
{{- $chost := "" }}
{{- $compiler_os := "" -}}
{{- $archive := ".tar.gz" -}}
{{- $exe_ext := "" -}}
{{- $is_desktop := false -}}
{{- $is_laptop := false -}}
{{- $is_phone := false -}}
{{- $is_tablet := false -}}
{{- $has_battery := false -}}
{{- $secrets_system := dict -}}
{{- $shell := "" -}}
{{- $default_wsl_distro := "" -}}
{{- $copy_command := "" -}}
{{- $paste_command := "" -}}
{{- $line_end := "\n" -}}
{{- $home := .chezmoi.homeDir -}}
{{- /* OS information */ -}}
{{- $is_wsl := not (eq (env "WSL_DISTRO_NAME") "") -}}{{/* true if this machine is a WSL instance */}}
{{- $is_linux := eq .chezmoi.os "linux" -}}{{/* true if this machine is a Linux machine */}}
{{- $is_windows := eq .chezmoi.os "windows" -}}{{/* true if this machine is a Windows machine */}}
{{- $is_macos := false -}}{{/* true if this machine is a macOS machine */}}
{{- /* Default values/placeholders for variables */ -}}
{{- $fullname := "Lev Velykoivanenko" -}}
{{- $firstname := "Lev" -}}
{{- $lastname := "Velykoivanenko" -}}
{{- $email := "velykoivanenko.lev@gmail.com" -}}
{{- $editor := "" }}
{{- $editor_path := "" }}
{{- $editor_args := list }}
{{- $hostname := .chezmoi.hostname -}}
{{- /* Encryption/Security */ -}}
{{- $gpg_key := "9D8D7DDC484386DE" -}}
{{- $age_key_file := (joinPath .chezmoi.homeDir ".config" "chezmoi" "key.txt") -}}
{{- $has_age_key := stat $age_key_file -}}
{{- $age_identities := list -}}
{{- $age_recipients := list -}}
{{- if $has_age_key -}}
  {{- $age_identities = append $age_identities $age_key_file -}}
  {{- $age_key_contents := include $age_key_file -}}
  {{- range $line := splitList "\n" $age_key_contents -}}
    {{- if hasPrefix "# public key: " $line -}}
      {{- $age_recipients = append $age_recipients (trimPrefix "# public key: " $line) -}}
    {{- end -}}
  {{- end -}}
{{- end -}}
{{- $has_keepassxc := false -}}
{{- $keepassxc_cli := "" -}}
{{- $keepassxc_database := "" -}}
{{- $keepassxc_args := list -}}
{{- $has_secrets := false -}}
{{- $secrets_key := "" -}}
{{- $secrets_path := joinPath .chezmoi.homeDir ".config" "chezmoi" "secrets.toml" -}}
{{- $secrets := dict -}}
{{- if stat $secrets_path -}}
  {{- $has_secrets = true -}}
  {{- $secrets = include $secrets_path | fromToml -}}
{{- end -}}
{{- "" -}}
{{- $has := dict -}}
{{- $tools := include ".chezmoidata/tools.toml" | fromToml -}}
{{- range $tool := $tools.tools -}}
  {{- range $cmd := $tool.cmds -}}
    {{- $has = merge $has (dict ( $cmd | replaceAllRegex "[-\\.]" "_" ) false) -}}
  {{- end -}}
{{- end -}}
{{- if $is_wsl -}}
  {{- $wsl_tools := include ".chezmoidata/wsl_tools.toml" | fromToml -}}
  {{- range $tool := $wsl_tools.wsl_tools -}}
    {{- range $cmd := $tool.cmds -}}
      {{- $has = merge $has (dict ( $cmd | replaceAllRegex "[-\\.]" "_" ) false) -}}
    {{- end -}}
  {{- end -}}
{{- end -}}
{{- $has_has := false -}}
{{- $has_path := joinPath .chezmoi.homeDir ".config" "chezmoi" "has.toml" -}}
{{- if stat $has_path -}}
  {{- $has_has = true -}}
  {{- $has = include $has_path | fromToml -}}
{{- end -}}


{{- $osID := .chezmoi.os -}}
{{- if (and (eq .chezmoi.os "linux") (hasKey .chezmoi.osRelease "id")) -}}
  {{- $osID = printf "%s-%s" .chezmoi.os .chezmoi.osRelease.id -}}
{{- end -}}

{{/* detect GitHub codespaces, VSCode remote containers, Docker containers, Multipass VMs, and Vagrant boxes */}}
{{- if or (env "CODESPACES") (env "REMOTE_CONTAINERS_IPC") (eq .chezmoi.username "root" "ubuntu" "vagrant" "vscode" "webmaster") -}}
  {{- $is_ephemeral = true -}}
  {{- $is_headless = true -}}
{{- end -}}

{{/* work around unreliable hostname on darwin */}}
{{- $hostname = .chezmoi.hostname -}}
{{- if eq .chezmoi.os "darwin" -}}
  {{- $hostname = output "scutil" "--get" "LocalHostName" | trim -}}
{{- end -}}

{{- /* Identify if running on ephemeral machine */ -}}
{{- if eq .chezmoi.os "" -}}
  {{- $is_ephemeral = true -}}
{{- end -}}

{{- /* Check for numbered keys (e.g., 1 to 5) */ -}}
{{- /* range $i := (seq 1 5 | splitList " ") */ -}}
  {{- /* if stat (joinPath $.chezmoi.homeDir (printf ".config/chezmoi/key%d.txt" (int $i))) */ -}}
    {{- /* $has_age_key = true */ -}}
    {{- /* break */ -}}
  {{- /* end */ -}}
{{- /* end */ -}}

{{- /* Identify hostname and set specific settings based on that */ -}}
{{- if not $is_ephemeral -}}
{{-   if ($is_wsl) -}}
{{-     $is_headless = true -}}
{{-     $is_personal = true -}}
{{-     $secrets_key = "wsl" -}}
{{-   else if (and ($is_windows) (or (contains "Yin" $hostname) (contains "GLaDOS" $hostname))) -}}
{{-     $is_personal = true -}}
{{-     $secrets_key = "windows" -}}
{{-   else if eq $hostname "ubuntu" -}}
{{-     $is_headless = true -}}
{{-     $is_personal = true -}}
{{-   else if eq $hostname "work_hostname" -}}
{{-     $is_work = true -}}
{{- /*   else if stdinIsATTY */ -}}
{{- /*     $is_headless = promptBoolOnce . "is_headless" "is_headless" */ -}}
{{- /*     $is_ephemeral = promptBoolOnce . "is_ephemeral" "is_ephemeral" */ -}}
{{-   else -}}
{{-     $is_ephemeral = true -}}
{{-     $is_headless = true -}}
{{-   end -}}
{{- end -}}

{{- /* General per os settings */ -}}
{{- if $is_linux -}}
  {{- $line_end = "\n" -}}
  {{- if index $has "wl_copy" | default (lookPath "wl_copy") -}}
    {{- $copy_command = "wl-copy" -}}
    {{- $paste_command = "wl-paste" -}}
  {{- else -}}
    {{- $copy_command = "xclip -i -selection clipboard" -}}
    {{- $paste_command = "xclip -o -selection clipboard" -}}
  {{- end -}}
  {{- if $is_wsl -}}
    {{- if and (index $has "wsl_exe") $has.wsl_exe -}}
      {{- $wslList := output "wsl.exe" "--list" | replace "\r" "" | replace "\x00" "" -}}
      {{- range $line := splitList "\n" $wslList -}}
        {{- if contains "(Default)" $line -}}
          {{- $default_wsl_distro = $line | replace " (Default)" "" | trim -}}
        {{- end -}}
      {{- end -}}
    {{- end -}}
  {{- end -}}
{{- else if $is_macos -}}
  {{- $line_end = "\n" -}}
  {{- $copy_command = "pbcopy" -}}
  {{- $paste_command = "pbpaste" -}}
{{- else if $is_windows -}}
  {{- $line_end = "\r\n" -}}
  {{- $copy_command = "Set-Clipboard" -}}
  {{- $paste_command = "Get-Clipboard" -}}
  {{- if and (index $has "wsl_exe") $has.wsl_exe -}}
    {{- $wslList := output "wsl.exe" "--list" | replace "\r" "" | replace "\x00" "" -}}
    {{- range $line := splitList "\n" $wslList -}}
      {{- if contains "(Default)" $line -}}
        {{- $default_wsl_distro = $line | replace " (Default)" "" | trim -}}
      {{- end -}}
    {{- end -}}
  {{- end -}}
{{- end -}}

{{- if $is_work -}}
{{- end -}}

{{- if (and $is_windows $is_personal) -}}
{{- end -}}

{{- if $is_linux -}}
{{- else if $is_windows -}}
{{- $archive = ".zip" -}}
{{- $exe_ext = ".exe" -}}
{{- end -}}

{{- /* Identify editor */ -}}
{{- if index $has "nvim" | default (lookPath "nvim") }}
  {{- $editor = "nvim" }}
  {{- $editor_path = "nvim" }}
  {{- $nvim_arch := "x86_64" -}}
  {{- if eq .chezmoi.arch "arm64" -}}
    {{- $nvim_arch = "arm64" -}}
  {{- end -}}
  {{- $nvim_os := .chezmoi.os -}}
  {{- if $is_macos -}}
    {{- $nvim_os = "macos" -}}
  {{- end -}}
  {{- $nvim_asset := printf "nvim-$s-%s" $nvim_os $nvim_arch -}}
  {{- if and $is_windows (eq $nvim_arch "x86_64") -}}
    {{- $nvim_asset = "nvim-win64" -}}
  {{- end -}}
  {{- $nvim_bin := joinPath .chezmoi.homeDir ".local" "bin" $nvim_asset "bin" (printf "nvim%s" $exe_ext ) -}}
  {{- if stat $nvim_bin -}}
    {{- $editor_path = $nvim_bin -}}
  {{- end -}}
{{- else if index $has "vim" | default (lookPath "vim") }}
  {{- $editor = "vim" }}
  {{- $editor_path = lookPath "vim" }}
{{- else if index $has "zed" | default (lookPath "zed") }}
  {{- $editor = "zed" }}
  {{- $editor_path = lookPath "zed" }}
{{- else if index $has "nano" | default (lookPath "nano") }}
  {{- $editor = lookPath "nano" }}
  {{- $editor_path = "nano" }}
{{- else if index $has "code" | default (lookPath "code") }}
  {{- $editor = "code" }}
  {{- $editor_path = lookPath "code" }}
  {{- $editor_args = list "--wait" }}
{{- end }}

{{- if and (hasKey $secrets "system") (index $secrets.system $hostname) -}}
  {{- $secrets_system = (index $secrets.system $hostname) -}}
{{- end -}}

{{- /* Set values based on secrets */ -}}
{{- if (and ($is_personal) ($secrets)) -}}
  {{- $fullname = $secrets.name.fullname -}}
  {{- $firstname = $secrets.name.firstname -}}
  {{- $lastname = $secrets.name.lastname -}}
  {{- $email = $secrets.email.personal -}}
  {{- $gpg_key = $secrets.gpg.gpg_key -}}
  {{- if index $secrets.keepassxc $secrets_key -}}
    {{- $keepassxc_cli = (index $secrets.keepassxc $secrets_key).cli -}}
    {{- $keepassxc_database = (index $secrets.keepassxc $secrets_key).database -}}
    {{- $keepassxc_args = (index $secrets.keepassxc $secrets_key).args | toJson -}}
  {{- end -}}

  {{- if $secrets_system.shell -}}
    {{- $shell = index $secrets_system |  default "" -}}
  {{- end -}}
  {{- if $secrets_system.wsl_shell -}}
    {{- $shell = $secrets_system.wsl_shell -}}
  {{- end -}}
  {{- /* if $is_wsl */ -}}
  {{- /* else if $is_linux */ -}}
  {{- /* else if $is_macos */ -}}
  {{- /* else if $is_windows */ -}}
  {{- /* end */ -}}
{{- end -}}

{{- /* Set system values */ -}}
{{- if eq .chezmoi.arch "amd64" -}}
  {{- $arch = "x86_64" -}}
{{- else if eq .chezmoi.arch "386" -}}
  {{- $arch = "x86" -}}
{{- else if eq .chezmoi.arch "arm64" -}}
  {{-   $arch = "aarch64" -}}
{{- else if eq .chezmoi.arch "arm" -}}
  {{-   $arch = "arm" -}}
{{- else if eq .chezmoi.arch "riscv64" -}}
  {{-   $arch = "riscv64" -}}
{{- else if eq .chezmoi.arch "ppc64le" -}}
  {{-   $arch = "powerpc64le" -}}
{{- else if eq .chezmoi.arch "s390x" -}}
  {{-   $arch = "s390x" -}}
{{- end -}}

{{- if $arch -}}
  {{- if $is_linux -}}
  {{- if eq .chezmoi.osRelease.idLike "debian" -}}
    {{- $compiler_os = "pc-linux-gnu" -}}
  {{- else -}}
    {{- $compiler_os = "unknown-linux-musl" -}}
  {{- end -}}
  {{- else if $is_windows -}}
    {{- $compiler_os = "pc-windows-msvc" -}}
  {{- else if $is_macos -}}
    {{- $compiler_os = "apple-darwin" -}}
  {{- else -}}
    {{- $compiler_os = printf "%s%s" "unknown-" .chezmoi.os -}}
  {{- end -}}
{{- end -}}
{{- $chost = printf "%s-%s" $arch $compiler_os -}}



{{ if and (hasKey $secrets "system") (hasKey $secrets.system $hostname) -}}
  {{- /* (index $secrets.system $hostname) | toToml */ -}}
  {{- $secrets_system := (index $secrets.system $hostname) -}}
  {{- $is_desktop = $secrets_system.is_desktop -}}
  {{- $is_laptop = $secrets_system.is_laptop -}}
  {{- $is_phone = $secrets_system.is_phone -}}
  {{- $is_tablet = $secrets_system.is_tablet -}}
{{- else -}}
  {{- /* Assume a laptop by default */ -}}
  {{- $is_desktop = false -}}
  {{- $is_laptop = true -}}
  {{- $is_phone = false -}}
  {{- $is_tablet = false -}}
{{ end -}}

{{""}}
{{- /* Start writing actual config file */ -}}
{{- if ($has_age_key) -}}
encryption = "age"

[age]
identities = {{ $age_identities | toToml }}
recipients = {{ $age_recipients | toToml }}

{{ end }}

{{- "" -}}

[edit]
command = {{ $editor | quote }}
args = {{ $editor_args }}
hardlink = {{ not $is_wsl }}

[github]
refreshPeriod = "12h"

[keepassxc]
command = "{{ $keepassxc_cli }}"
database = "{{ $keepassxc_database }}"
args = {{ $keepassxc_args }}
mode = "open"

[merge]
{{ if eq $editor "nvim" -}}
command = {{ $editor | quote }}
args = ["-d", {{ printf "%q" "{{ .Destination }}" }}, {{ printf "%q" "{{ .Source }}" }}, {{ printf "%q" "{{ .Target }}" }}]
{{- end }}

# Data for use in templates
[data]
arch = {{ $arch | quote }}
arch_go = {{ dict "x86_64" "amd64" "aarch64" "arm64" | dig .chezmoi.arch .chezmoi.arch | quote }}
chost = {{ $chost | quote }}
compiler_os = {{ $compiler_os | quote }}
archive = {{ $archive | quote }}
exe_ext = {{ $exe_ext | quote }}
# OS booleans
is_wsl = {{ $is_wsl }}
is_linux = {{ $is_linux }}
is_macos = {{ $is_macos }}
is_windows = {{ $is_windows }}
# System info
is_work = {{ $is_work }}
is_personal = {{ $is_personal }}
is_ephemeral = {{ $is_ephemeral }}
is_headless = {{ $is_headless }}
is_desktop = {{ $is_desktop }}
is_laptop = {{ $is_laptop }}
is_phone = {{ $is_phone }}
is_tablet = {{ $is_tablet }}
{{ if $shell -}}
shell = {{ $shell | quote }}
{{- else -}}
shell = {{ env "SHELL" | base | quote }}
{{- end }}
zshPlugins = [
    "per-directory-history",
    "vi-mode",
    "zsh-syntax-highlighting",
]

[data.font]
monospace = [
    "Sarasa Fixed K",
    "NanumGothicCoding",
    "Symbols Nerd Font Mono",
    "Symbols Nerd Font",
    "MesloLGM Nerd Font Propo",
    "Atkinson Hyperlegible Mono",
    "Noto Sans Mono CJK KR",
    "Noto Sans Mono CJK SC",
    "Noto Sans Mono CJK HK",
    "Noto Sans Mono CJK JP",
    "Noto Sans Mono CJK TC",
    "Meslo LG S",
    "Menlo",
    "Consolas",
    "Font Awesome 6 Pro",
    "Twemoji Mozilla",
]

[data.path]
home = {{ $home | quote }}
{{ if stat (joinPath $home ".cargo") -}}
cargo_dir = {{ joinPath $home ".cargo" | quote}}
cargo_bin_dir = {{ joinPath $home ".cargo" "bin" | quote}}
{{- else -}}
cargo_dir = ""
cargo_bin_dir = ""
{{- end }}
editor = {{ $editor_path | quote }}
{{ if stat (joinPath $home "go") -}}
go_dir = {{ joinPath $home "go" | quote}}
go_bin_dir = {{ joinPath $home "go" "bin" | quote}}
{{- else -}}
go_dir = ""
go_bin_dir = ""
{{- end }}
{{- if eq $editor "nvim" }}
nvim = {{ $editor_path | replaceAllRegex "\\\\" "/" | quote }}
{{- else -}}
nvim = ""
{{- end }}

[data.age]
identities = {{ $age_identities | toToml }}
recipients = {{ $age_recipients | toToml }}

[data.cache]
[data.cache.build]
shell = {{ and $is_personal (not $is_ephemeral) }}
bash = {{ and $is_personal (not $is_ephemeral) }}
fish = {{ and $is_personal (not $is_ephemeral) }}
zsh = {{ and $is_personal (not $is_ephemeral) }}

[data.personal]
# Personal info
email = {{ $email | quote }}
fullname = {{ $fullname | quote }}
firstname = {{ $firstname | quote }}
lastname = {{ $lastname | quote }}
gpg_key = {{ $gpg_key | quote }}

[data.system]
has_nightly_rust = {{ output "rustup" "toolchain" "list" | contains "nightly" }}
has_battery = {{ not $is_desktop }}
hostname = {{ $hostname | quote }}
osid = {{ $osID | quote }}
editor = {{ $editor | quote }}
default_wsl_distro = {{ $default_wsl_distro | quote }}
path_sep = {{ .chezmoi.pathSeparator | quote }}
copy_command = {{ $copy_command | quote }}
paste_command = {{ $paste_command | quote }}

# Has
[data.has]
{{ toToml $has -}}
{{ "" }}

# Secrets
{{ "" }}
{{- $data_secrets := dict "data" (dict "secrets" $secrets) -}}
{{- toToml $data_secrets | replace "[data]\n" "" | replaceAllRegex "^\\s+" "" | replaceAllRegex "\n\\s+" "\n" -}}
