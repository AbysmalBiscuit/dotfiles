#!/bin/bash
# ~/.bashrc
#

{{ template "sh/debug_startup_start.sh" }}

{{ template "sh/rc.sh" }}

{{ template "sh/utility_functions.sh" }}

{{/* Only cache env on personal and non-ephemeral systems */ -}}
{{ if .cache.build.shell }}
{{ template "shell_env_cache_build.sh" . }}
{{- else -}}
# add additional environment variables
[[ -s "$HOME/.sh_env" ]] && source "$HOME/.sh_env"

# If not running interactively, stop here
[[ $- != *i* ]] && return

{{ template "sh/env_wsl.sh" . }}
{{ end -}}

# enable gpg integration
export GPG_TTY=$(tty)

# Starting fish shell, and make sure to exit after
if [[ -x $(command -v fish 2>/dev/null) && -z "$BASH_EXECUTION_STRING" && "$FORCESH" != "1" && (! -v ZED_TERM || "$ZED_TERM" != "true") ]]; then
    source "$env_cache"
    {{ template "sh/debug_startup_end.sh" }}

    exec fish
fi

# if grep -qv 'fish' /proc/$PPID/comm && [[ ${SHLVL} == [1,2] && "$FORCEBASH" != "1" ]]; then
#     shopt -q login_shell && LOGIN_OPTION='--login' || LOGIN_OPTION=''
#     echo $LOGIN_OPTION
#     exec fish $LOGIN_OPTION
# fi

{{ if .cache.build.shell -}}
source "$interactive_cache"
{{- else -}}
{{ template "bash/rc.bash" }}

# Configuration for the terminal prompt
# set a fancy prompt (non-color, unless we know we "want" color)
case "$TERM" in
xterm-color) color_prompt=yes ;;
esac

# uncomment for a colored prompt, if the terminal has the capability; turned
# off by default to not distract the user: the focus in a terminal window
# should be on the output of commands, not on the prompt
force_color_prompt=yes

if [[ -n "$force_color_prompt" ]]; then
    if [[ -x /usr/bin/tput ]] && tput setaf 1 >&/dev/null; then
        # We have color support; assume it's compliant with Ecma-48
        # (ISO/IEC-6429). (Lack of such support is extremely rare, and such
        # a case would tend to support setf rather than setaf.)
        color_prompt=yes
    else
        color_prompt=
    fi
fi

if [[ "$color_prompt" = yes ]]; then
    ESC=$(printf "\e")
    if [[ "$EUID" -ne 0 ]]; then
        # Prompt for regular users is colored green
        PS1='[\[\033[01;32m\]\u@\h\[\033[00m\] \[\033[01;34m\]\W\[\033[00m\]]\$ '
        #PS1='[\e]4;1;rgb:11/CF/45\e\\\e[31m\e[1m\u@\h\[\033[00m\] \[\033[01;34m\]\W\[\033[00m\]]\$ '
    else
        # Prompt for root is colored red
        PS1='[\[\033[01;31m\]\u@\h\[\033[00m\] \[\033[01;34m\]\W\[\033[00m\]]\$ '
    fi
else
    PS1='[\u@\h \W]\$ '
fi
unset color_prompt force_color_prompt

# If this is an xterm set the title to user@host:dir
case "$TERM" in
xterm* | rxvt*)
    PS1="\[\e]0;\u@\h: \W\a\]$PS1"
    ;;
*) ;;
esac

{{ template "sh/extensions.sh" . }}
{{- end }}

{{ template "sh/debug_startup_end.sh" }}

# Avoid error message after shell start
return 0
