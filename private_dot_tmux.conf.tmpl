set-environment -g LANG "en_US.UTF-8"

set -g base-index 1
# set -g renumber-windows
setw -g pane-base-index 1

# Keep manually-set window names (e.g. a script's `rename-window pr123[ENG-456]`).
# Without these, Claude Code's terminal-title escapes (allow-rename) and
# process tracking (automatic-rename) overwrite the name with the last command.
setw -g automatic-rename off
set -g allow-rename off

# Publish the active pane's edge position to the outer terminal title so
# WezTerm can tell when the inner stack is against a wall and should hand
# Ctrl+Arrow off to its own pane navigation (see innerHandles in ~/.wezterm.lua).
# A letter (L/R/U/D) marks a direction the inner stack CAN'T move: the tmux pane
# touches that window edge AND nvim has no split that way. nvim publishes its own
# edges into @nvim_edges (see the Navigator config in lua/plugins/editor.lua);
# the default "LRUD" means a non-nvim pane is blocked at the nvim level, so only
# tmux's own edges matter there.
#
# The cwd basename is appended after the edges as "tmux:<edges> <cwd>". WezTerm
# strips the "tmux:<edges>" prefix and shows the cwd as the tab title (see
# tab_title in ~/.wezterm.lua); the edges still parse because they are uppercase
# letters terminated by the space before the path.
set -g @nvim_edges "LRUD"
set -g set-titles on
set -g set-titles-string "tmux:#{?#{&&:#{pane_at_left},#{m:*L*,#{@nvim_edges}}},L,}#{?#{&&:#{pane_at_right},#{m:*R*,#{@nvim_edges}}},R,}#{?#{&&:#{pane_at_top},#{m:*U*,#{@nvim_edges}}},U,}#{?#{&&:#{pane_at_bottom},#{m:*D*,#{@nvim_edges}}},D,} #{b:pane_current_path}"

# Auto renumebr the indices when some windows/tabs close
set -g renumber-windows on

# Make a better prefix binding
unbind C-b
unbind r
bind r source-file ~/.tmux.conf \; display-message "tmux.conf reloaded"

# tmux-256color (not *-direct): tcell-based TUIs (lazygit) mis-parse direct-color
# terminfo and render hex colors as garbage. Truecolor still works — the RGB
# override below forwards 24-bit color to the outer terminal, and COLORTERM lets
# inner apps detect it.
set -g default-terminal "tmux-256color"
set -ag terminal-overrides ",xterm-256color:RGB"

# Forward OSC 8 hyperlinks (e.g. `issue status`/`issue prs` clickable URLs) out
# to the outer terminal. tmux only passes them through when the outer term is
# known to support them, which tmux-256color terminfo doesn't advertise.
set -as terminal-features '*:hyperlinks'

# Inside tmux, TERM_PROGRAM is forced to "tmux", so Rust's supports-hyperlinks
# crate (used by devkit's `issue` CLI) stops emitting OSC 8 at all. Force it on
# so the escape is produced; the feature line above lets tmux relay it.
set-environment -g FORCE_HYPERLINK 1


set -g allow-passthrough all
set -ga update-environment TERM
set -ga update-environment TERM_PROGRAM

set -g prefix C-/
# Many terminals (incl. WezTerm) send 0x1f for Ctrl+/, which tmux sees as C-_.
# Register it as a secondary prefix so Ctrl+/ works regardless of what is sent.
set -g prefix2 C-_
