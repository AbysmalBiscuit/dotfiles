set -g status-right-length 100
set -g status-left-length 100
set -g status-left ""
# Two-row status bar:
#   row 0 (top)    = catppuccin info modules (utils), right-aligned
#   row 1 (bottom) = the window/session pills (full width, not squished)
# Modules live in status-format[0]; the window list in status-format[1] (tmux's
# default window-list rendering, copied verbatim so mouse selection and styling
# keep working).
set -g status 2
set -g status-right ""
set -g status-format[0] "#[align=right]#[push-default]"
set -ga status-format[0] "#{E:@catppuccin_status_application}"
# set -ag status-right "#[bg=#{@thm_green},fg=#{@thm_crust}]#[reverse]#[noreverse] "
set -ga status-format[0] "#(tmux-spotify-info)"
set -gaF status-format[0] "#{E:@catppuccin_status_cpu}"

# set -ag status-right "#[bg=#{@thm_green},fg=#{@thm_crust}]#[reverse]#[noreverse] "
set -ga status-right "#(tmux-spotify-info)"
# CPU lives on the top status row (status-format[0]); see cpu-interpolate-format.sh.
# 
# {{- if .is_macos }}
set -ag status-right "#[bg=#{@thm_flamingo},fg=#{@thm_crust}]#[reverse]#[noreverse]󱀙  "
set -ag status-right "#[fg=#{@thm_fg},bg=#{@thm_mantle}] #(memory_pressure | awk '/percentage/{print $5}') "
