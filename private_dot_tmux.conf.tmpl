# Run plugin manager
set -g @plugin 'tmux-plugins/tpm'
run '~/.tmux/plugins/tpm/tpm'

# tmux-cpu only interpolates status-left/status-right; apply the same CPU
# placeholder substitution to the top status row so its CPU module renders.
run-shell '~/.tmux/cpu-interpolate-format.sh'

