set LANG="en_US.UTF-8"

set -g base-index 1
# set -g renumber-windows
setw -g pane-base-index 1

# Make a better prefix binding
unbind C-b
unbind r
bind r source-file ~/.tmux.conf

set -g default-terminal "tmux-256color"
set -ag terminal-overrides ",xterm-256color:RGB"


set -g allow-passthrough all
set -ga update-environment TERM
set -ga update-environment TERM_PROGRAM

set -g prefix C-/
# unbind-key C-/
# bind-key C-/ send-prefix
# set -g prefix C-s

set -g mouse on

set-window-option -g mode-keys vi
# set-option -g xterm-keys on
set-option -s escape-time 10
set-option -g focus-events on

# Smart pane switching with awareness of Vim splits.

bind-key -r f run-shell "tmux neww ~/.local/bin/tmux-sessionizer"

bind-key h select-pane -L
bind-key j select-pane -D
bind-key k select-pane -U
bind-key l select-pane -R

bind -n C-Pageup  previous-window
bind -n C-Pagedown next-window

bind -T root C-Left select-pane -L
bind -T root C-Down select-pane -D
bind -T root C-Up select-pane -U
bind -T root C-Right select-pane -R

set-option -g status-position top

# Re-enable home and end keys
{{- if .os.is_wsl -}}
  bind-key -n Home send-keys \033[H
  bind-key -n End send-keys \033[F
{{- else if .os.is_macos -}}
bind-key -n Home send Escape "OH"
bind-key -n End send Escape "OF"
{{- end -}}
# Add default opening methods as fallback
# bind c new-window -c "#{pane_current_path}"
# bind '"' split-window -c "#{pane_current_path}"
# bind % split-window -h -c "#{pane_current_path}"

# Set new panes to open in current directory
bind M-c new-window -c "#{pane_current_path}"
bind M-'"' split-window -c "#{pane_current_path}"
bind M-% split-window -h -c "#{pane_current_path}"

# Plugins
set -g @plugin 'catppuccin/tmux'
# set -g @plugin 'christoomey/vim-tmux-navigator'
#
# set -g @vim_navigator_mapping_left "M-Left"  # use C-h and C-Left
# set -g @vim_navigator_mapping_right "M-Right"
# set -g @vim_navigator_mapping_up "M-Up"
# set -g @vim_navigator_mapping_down "M-Down"
# set -g @vim_navigator_mapping_prev ""  # removes the C-\ binding

version_pat='s/^tmux[^0-9]*([.0-9]+).*/\1/p'

is_vim="ps -o state= -o comm= -t '#{pane_tty}' \
    | grep -iqE '^[^TXZ ]+ +(\\S+\\/)?g?(view|n?vim?x?)(diff)?$'"
bind-key -n C-Left if-shell "$is_vim" "send-keys C-Left" "select-pane -L"
bind-key -n C-Down if-shell "$is_vim" "send-keys C-Down" "select-pane -D"
bind-key -n C-Up if-shell "$is_vim" "send-keys C-Up" "select-pane -U"
bind-key -n C-Right if-shell "$is_vim" "send-keys C-Right" "select-pane -R"
tmux_version="$(tmux -V | sed -En "$version_pat")"
setenv -g tmux_version "$tmux_version"

# if-shell -b '[ "$(echo "$tmux_version < 3.0" | bc)" = 1 ]' \
