# Sourcing external packages
# {{ if .cache.build.shell }}
[[ -s "$HOME/.sh_cache" ]] && source "$HOME/.sh_cache"
# {{- else -}}
# {{ template "zsh/rc.zsh" . }}
# {{- end }}

# Starting fish shell
if [[
    -x $(command -v fish 2>/dev/null) &&
    -z "$BASH_EXECUTION_STRING" &&
    x"$FORCESH" != x"1" &&
    (! -v ZED_TERM || "$ZED_TERM" != "true") ]] \
    ; then
    source "# {{ .chezmoi.homeDir }}/.cache/# {{ $shell }}/env.# {{ $shell }}"
    exec fish
fi

# {{ if .cache.build.shell -}}
source "$interactive_cache"
# {{- else -}}
# {{ template "sh/extensions.sh" . }}
# {{- end }}

# {{ template "sh/debug_startup_end.sh" }}

# Avoid error message after shell start
return 0
