# Starship modules
## Basic prompt features
[battery]
disabled = {{ not .system.has_battery }}
format = "[\b $symbol$percentage]($style bg:bg_time) "
unknown_symbol = "?"
display = [
    { threshold = 10, style = 'bold red' },
    { threshold = 30, style = 'bold orange' },
    { threshold = 50, style = 'bold yellow' },
    { threshold = 80, style = 'bold green1' },
    { threshold = 100, style = 'bold green' },
]

[character]
disabled = false
# Note the use of Catppuccin color 'peach'
# success_symbol = "[[¾░äø](green) ŌØ»](peach)"
# error_symbol = "[[¾░äø](red) ŌØ»](peach)"
# vimcmd_symbol = "[¾░äø ŌØ«](subtext1)" # For use with zsh-vi-mode
#
success_symbol = '[\[I\]ŌØ»](bold green)'
error_symbol = '[\[I\]ŌØ»](bold red)'
vimcmd_symbol = '[\[N\]ŌØ»](bold blue)'
vimcmd_replace_one_symbol = '[\[R\]ŌØ»](bold red)'
vimcmd_replace_symbol = '[\[R\]ŌØ»](bold red)'
# vimcmd_visual_symbol = '[ŌØ«](bold #cba6f7)'
vimcmd_visual_symbol = '[\[V\]ŌØ»](bold #cba6f7)'

format = '$symbol '
# success_symbol = "[ŌŚÄ](bold italic bright-yellow)"
# error_symbol = "[ŌŚŗ](italic purple)"
# vimcmd_symbol = "[Ō¢Ā](italic dimmed green)"
# not supported in zsh
# vimcmd_replace_one_symbol = "ŌŚī"
# vimcmd_replace_symbol = "Ō¢Ī"
# vimcmd_visual_symbol = "Ō¢╝"

[cmd_duration]
disabled = false
show_milliseconds = true
format = "[\b Ņ½┤  in $duration]($style) "
# style = "bg:lavender"
