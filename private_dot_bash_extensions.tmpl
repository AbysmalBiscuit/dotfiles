# vim:filetype=bash.chezmoitmpl
{{ if .has.starship -}}
{{output "starship" "init" "bash" "--print-full-init" }}

export STARSHIP_LOG=error
{{- end }}
{{ if .has.sk -}}
{{ output "sk" "--shell" "bash" "--shell-bindings" }}

{{ else if .has.fzf -}}
{{ output "fzf" "--bash" }}

{{ end }}
{{ if .has.zoxide -}}
{{ output "zoxide" "init" "bash" }}
{{- end }}
