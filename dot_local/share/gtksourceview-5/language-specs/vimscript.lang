    <define-regex id="vim-syn-options-regex" extended="true">
      (keyword|match|cluster|region|case)?
    </define-regex>

    <context id="vim-syn-options">
      <keyword>keyword</keyword>
      <keyword>match</keyword>
      <keyword>cluster</keyword>
      <keyword>region</keyword>
      <keyword>case</keyword>
      <keyword>ignore</keyword>
      <keyword>sync</keyword>
    </context>

    <context id="vimSyntax" style-ref="vimSyntax" end-at-line-end="true">
      <start>^syn</start>
      <include>
        <context ref="vim-syn-options" style-ref="vimSyntax"/>
      </include>
    </context>













    <context id="vim-hi-options">
      <keyword>def</keyword>
      <keyword>link</keyword>
    </context>

    <context id="vim-hi-what-choice">
      <keyword>guifg\=</keyword>
      <keyword>guibg\=</keyword>
      <keyword>guisp\=</keyword>
      <keyword>gui\=</keyword>
      <keyword>ctermfg\=</keyword>
      <keyword>ctermbg\=</keyword>
      <keyword>cterm\=</keyword>
    </context>
