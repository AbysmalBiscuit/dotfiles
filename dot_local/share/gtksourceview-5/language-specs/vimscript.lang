    </context>

    <context id="vimHighlighting" end-at-line-end="true">
      <start extended="true">^\s*hi\s</start>
      <include>
        <context style-ref="keyword">
          <keyword>hi</keyword>
        </context>
        <context ref="vim-hi-options" style-ref="def:statement" />


        <context ref="vim-hi-what-choice" style-ref="function" />

        <context ref="vim-hi-config-values" style-ref="vimType" />

      </include>
    </context>

    <context id="vimscript" class="no-spell-check">
      <include>
        <context ref="line-comment"/>
        <context ref="single-quoted-string"/>
        <context ref="double-quoted-string"/>
        <context ref="punctuator"/>
        <context ref="function"/>
        <context ref="numeric"/>
        <context ref="variable"/>
        <context ref="variable-definition"/>
        <context ref="built-in-command"/>
        <context ref="vimCommand"/>
        <context ref="vimFuncName"/>
        <context ref="vimAutoEvent"/>
        <context ref="vimOption"/>
        <context ref="vimSyntax"/>
        <context ref="vimHighlighting"/>
      </include>
