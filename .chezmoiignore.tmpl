{{ end }}

{{ if not (eq .shell "zsh") -}}
.zsh*
.zprofile
.oh-my-zsh/**
{{- else -}}
!.oh-my-zsh/plugins
{{ range .zshPlugins }}
!.oh-my-zsh/plugins/{{ . }}
!.oh-my-zsh/plugins/{{ . }}/**
{{- end }}
.oh-my-zsh/cache/**
.oh-my-zsh/plugins/**
.oh-my-zsh/templates/**
{{- end }}


# specific cross-platform programs
{{ if .is_headless -}}
    {{- if not (index .has "dbeaver" | default false) }}
.config/dbeaver
    {{ end -}}
    {{- if not (index .has "iterm2" | default false) }}
.config/iterm2
    {{ end -}}
    {{- if not (index .has "mpv" | default false) }}
.config/mpv
    {{ end -}}
{{- end }}

