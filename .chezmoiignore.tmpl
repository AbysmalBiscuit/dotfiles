# os specific exclusions

{{ if .is_wsl -}}
.config/alacritty
.config/ghostty
.config/kanata
.config/kitty
.config/spotify-player
.wezterm.lua
{{- else -}}
.gnupg/pinentry-ide.sh
{{- end }}

{{ if not .is_macos }}
.chezmoiscripts/darwin/**
.config/aerospace
.config/homebrew
.config/Apple-Terminal
.config/karabiner
.config/iterm2
.hammerspoon
{{ end }}

{{ if not .is_linux }}
.chezmoiscripts/linux/**
.hushlogin
.local/bin/nvim
.local/share/fonts
.config/gnome-terminal
.config/devilspie2
{{- else -}}
{{ if not (index .has "devilspie2" | default false) -}}
.config/devilspie2
{{- end }}
{{ if not (index .has "gedit" | default false) -}}
.config/gedit
.local/share/gedit
.local/share/gtksourceview-5
{{- end }}
{{ if not (index .has "gnome_terminal" | default false) -}}
.config/gnome-terminal
{{- end }}
{{ end }}

{{ if .is_windows }}
**.sh
**.sh.tmpl
**\.sh*
