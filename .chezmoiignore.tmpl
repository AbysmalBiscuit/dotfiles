.config/git/cookies
.config/gitui
.config/kitty
.config/mpv
.config/psql
.config/readline
.config/tmux
.fimrc
.inputrc
.local/share/gedit/**
.local/share/gtksourceview-5/**
.oh-my-zsh
.oh-my-zsh/**
.p10k.zsh
.profile
.sh_*
.ssh/id_rsa
.ssh/id_rsa.pub
.tmux.conf
.xinitrc
.zprofile
.zsh*
{{ if not (lookPath "ConEmu.exe") -}}
AppData/Roaming/ConEmu.xml
{{- end }}
{{- else -}}
.chezmoiscripts/windows/**
AppData/**
Documents
**\.ps1
{{ end }}

{{ if not .personal }}
.aider.*
.claude/**
.config/ghostty
.config/ghostty/**
.config/psql
.config/psql/**
.hammerspoon
.hammerspoon/**
.psqlrc
.pypirc
.ssh
