  "editor.fontFamily": "'Sarasa Fixed K','MesloLGS Nerd Font Mono','Meslo LG S', Menlo, Monaco, Consolas, monospace,'Hack Nerd Font Mono'",
  "editor.fontLigatures": false,
  "editor.fontSize": 16,
  "editor.formatOnPaste": true,
  "editor.indentSize": "tabSize",
  "editor.lineNumbers": "relative",
  "editor.linkedEditing": true,
  "editor.minimap.enabled": false,
  "editor.rulers": [
    {
      "color": "#273E5C",
      "column": 80
    },
    {
      "color": "#273E5C",
      "column": 100
    },
    {
      "color": "#e5e5e5",
      "column": 120
    }
  ],
  "editor.semanticHighlighting.enabled": true,
  "editor.semanticTokenColorCustomizations": {
    "enabled": true,
    "rules": {
      "*.abstract": "#ff0000",
      "*.async": "#ff0000",
      "*.declaration": {
        "bold": true
      },
      "*.deprecated": "#ff0000",
      "*.documentation": "#ff0000",
      "*.modification": "#ff0000",
      "*.readonly": "#ff0000",
      "*.static": "#ff0000",
      "*.typeHint": {
        "bold": true,
        "foreground": "#91CCFF"
      },
      "*.typeHintComment": {
        "bold": true,
        "foreground": "#91CCFF"
      },
      "builtinConstant": {
        "bold": true,
        "foreground": "#FFA07A"
      },
      "class": {
        "bold": false,
        "foreground": "#ededed"
      },
      "class.builtin.decorator:python": {
        "bold": true,
        "foreground": "#FC7A00"
      },
      "class.builtin:python": {
        "bold": true,
        "foreground": "#aa00aa"
      },
      "class.declaration": {
        "bold": true
      },
      "clsParameter": {
        "foreground": "#FC7A00"
      },
      "comment": "#7f7f7f",
      "enum": {
        "bold": true,
        "foreground": "#c48aff"
      },
      "enumMember": "#7db8f5",
      "event": "#ff0000",
      "function": {
        "bold": false,
        "foreground": "#ededed"
      },
      "function.builtin": {
        "bold": true,
        "foreground": "#aa00aa"
      },
      "interface": {
        "bold": true,
        "foreground": "#91CCFF"
      },
      "keyword": {
        "bold": true,
        "foreground": "#558eff"
      },
      "label": "#ff0000",
      "macro": {
        "bold": true,
        "foreground": "#4AA532"
      },
      "magicFunction": {
        "bold": true,
        "foreground": "#aa00aa"
      },
      "method": {
        "bold": false,
        "foreground": "#ededed"
      },
      "method.builtin": {
        "bold": false,
        "foreground": "#ededed"
      },
      "method.declaration": {
        "bold": true
      },
      "module": {
        "bold": true,
        "foreground": "#80FFBB"
      },
      "namespace": {
        "bold": true,
        "foreground": "#80FFBB"
      },
      "number": "#ff9d00",
      "operator": "#ededed",
      "parameter": "#ededed",
      "property": {
        "bold": false,
        "foreground": "#ededed"
      },
      "python.readonly": {
        "fontStyle": "bold",
        "foreground": "#558eff"
      },
      "readonly": "#ff0000",
      "regexp": "#ff0000",
      "selfParameter": {
        "foreground": "#FC7A00"
      },
      "string": "#11CF45",
      "struct": {
        "bold": true,
        "foreground": "#80FFBB"
      },
      "type": "#91CCFF",
      "typeParameter": "#91CCFF",
      "variable": "#ededed",
      "variable.declaration": {
        "bold": false
      }
    }
  },
  "editor.showFoldingControls": "always",
  "editor.tabCompletion": "on",
  "editor.tabSize": 4,
  "editor.tokenColorCustomizations": {
    "comments": "#7f7f7f",
    "functions": "#f5f5f5",
    "keywords": "#558eff",
    "numbers": "#ff9d00",
    "strings": "#11CF45",
    "textMateRules": [
      {
        "name": "operator",
        "scope": [
          "punctuation.definition.arguments.begin.python",
          "punctuation.definition.arguments.end.python",
          "punctuation.definition.list.begin.python",
          "punctuation.definition.list.end.python",
          "punctuation.definition.typeparameters.begin.ts",
          "punctuation.definition.typeparameters.end.ts"
        ],
        "settings": {
          "foreground": "#e5e5e5"
        }
      },
      {
        "name": "keywords",
        "scope": [
          "keyword.control",
          "constant.language.python",
          "keyword.control.import.python",
          "storage.type.class.python",
          "storage.type.function.python",
          "keyword.operator.logical.python",
          "support.function.section.latex",
          "support.function.be.latex",
          "support.function.footnote.latex",
          "support.function.emph.latex",
          "support.function.general.tex",
          "support.function.builtin.shell",
          "support.function.command.fish",
          "support.function.builtin.fish",
          "support.function.unix.fish",
          "keyword.operator.new",
          "storage.modifier.ts",
          "storage.type",
          "entity.name.command.shell",
          "punctuation.definition.evaluation.parens.begin.shell",
          "punctuation.definition.evaluation.parens.end.shell",
          "constant.language.json.comments",
          "meta.diff.header.git"
        ],
        "settings": {
          "fontStyle": "bold",
          "foreground": "#558eff"
        }
      },
      {
        "name": "strings",
        "scope": [
          "storage.type.string.python",
          "string.quoted.single.python",
          "string.interpolated.python",
          "meta.fstring.python",
          "string.quoted.docstring.multi.python",
          "string.quoted.single.shell",
          "string.quoted.double.shell"
        ],
        "settings": {
          "fontStyle": "",
          "foreground": "#11CF45"
        }
      },
      {
        "name": "string escapes",
        "scope": [
          "constant.character.escape.python",
          "constant.character.format.placeholder.other.python",
          "meta.fstring.python",
          "source.python"
        ],
        "settings": {
          "fontStyle": "bold",
          "foreground": "#83A6C1"
        }
      },
      {
        "name": "function and class declaration",
        "scope": [
          "entity.name.function",
          "entity.name.type.class"
        ],
        "settings": {
          "fontStyle": "bold",
          "foreground": "#f5f5f5"
        }
      },
      {
        "name": "standard text",
        "scope": [
          "support.class.math.block.tex",
          "support.class.math.block.environment.latex",
          "meta.math.block.tex",
          "source.python",
          "source.shell",
          "text.tex.latex",
          "support.variable.magic.python",
          "string.unquoted.argument.shell",
          "meta.embedded"
        ],
        "settings": {
          "fontStyle": "",
          "foreground": "#e5e5e5"
        }
      },
      {
        "name": "type",
        "scope": [
          "support.type",
          "meta.diff.range.unified"
        ],
        "settings": {
          "fontStyle": "bold",
          "foreground": "#91CCFF"
        }
      },
      {
        "name": "builtin",
        "scope": [
          "support.type.exception.python",
          "support.type.python",
          "support.function.magic.python",
          "support.function.builtin.python"
        ],
        "settings": {
          "fontStyle": "bold",
          "foreground": "#AA00AA"
        }
      },
      {
        "name": "decorators and self",
        "scope": [
          "punctuation.definition.string.begin.latex",
          "punctuation.definition.string.end.latex",
          "punctuation.definition.string.begin.tex",
          "punctuation.definition.string.end.tex",
          "punctuation.definition.decorator.python",
          "entity.name.function.decorator.python",
          "meta.function.decorator.python",
          "meta.function.decorator.python support.type.python",
          "variable.language.special.self.python",
          "variable.parameter.function.language.special.self.python",
          "variable.parameter.function.language.special.cls.python",
          "variable.language.special.cls.python",
          "meta.decorator.ts"
        ],
        "settings": {
          "fontStyle": "",
          "foreground": "#FC7A00"
        }
      },
      {
        "name": "shebang",
        "scope": [
          "punctuation.definition.comment.shebang.shell",
          "comment.line.number-sign.shebang.shell",
          "meta.shebang.shell"
        ],
        "settings": {
          "fontStyle": "italic",
          "foreground": "#0088ff"
        }
      },
      {
        "scope": [
          "keyword.operator.redirect.fish"
        ],
        "settings": {
          "fontStyle": "bold",
          "foreground": "#ffaf87"
        }
      },
      {
        "name": "cli flags",
        "scope": [
          "source.option.fish",
          "constant.other.option.dash.shell",
          "constant.other.option.shell"
        ],
        "settings": {
          "foreground": "#FFFAB1"
        }
      },
      {
        "name": "LaTeX extra keywords",
        "scope": [
          "punctuation.definition.constant.math.tex",
          "constant.other.general.math.tex"
        ],
        "settings": {
          "fontStyle": "bold",
          "foreground": "#569CD6"
        }
      },
      {
        "name": "diff:index",
        "scope": [
          "meta.diff.index.git"
        ],
        "settings": {
          "foreground": "#666666"
        }
      },
      {
        "name": "diff:diff-file",
        "scope": [
          "meta.diff.header.from-file",
          "meta.diff.header.to-file"
        ],
        "settings": {
          "foreground": "#0088ff"
        }
      },
      {
        "name": "markup deleted",
        "scope": [
          "markup.deleted"
        ],
        "settings": {
          "foreground": "#CC6666"
        }
      },
      {
        "name": "markup inserted",
        "scope": [
          "markup.inserted"
        ],
        "settings": {
          "foreground": "#408040"
        }
      },
      {
        "name": "markup changed",
        "scope": "markup.changed",
        "settings": {
          "foreground": "#4D6F99"
        }
      }
    ],
    "types": "#91CCFF",
    "variables": "#FFFAB1"
  },
