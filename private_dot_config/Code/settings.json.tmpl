        "j"
      ]
    },
    {
      "after": [
        "<C-w>",
        "h"
      ],
      "before": [
        "<C-h>"
      ]
    },
    {
      "after": [
        "<C-w>",
        "h"
      ],
      "before": [
        "<C-left>"
      ]
    },
    {
      "after": [
        "<C-w>",
        "j"
      ],
      "before": [
        "<C-j>"
      ]
    },
    {
      "after": [
        "<C-w>",
        "j"
      ],
      "before": [
        "<C-up>"
      ]
    },
    {
      "after": [
