        "k"
      ],
      "before": [
        "<C-k>"
      ]
    },
    {
      "after": [
        "<C-w>",
        "k"
      ],
      "before": [
        "<C-down>"
      ]
    },
    {
      "after": [
        "<C-w>",
        "l"
      ],
      "before": [
        "<C-l>"
      ]
    },
    {
      "after": [
        "<C-w>",
        "l"
      ],
      "before": [
        "<C-right>"
      ]
    },
    {
      "before": [
        "<Leader>",
        "t",
        "t"
      ],
      "commands": [
        ":tabnew"
      ]
    },
    {
      "before": [
        "<Leader>",
        "t",
        "n"
      ],
      "commands": [
        ":tabnext"
      ]
    },
    {
      "before": [
        "<Leader>",
        "t",
