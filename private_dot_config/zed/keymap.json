  {
    "context": "vim_mode == visual",
    "bindings": {
      ":": "vim::VisualCommand",
      "ctrl-;": "vim::VisualCommand",
      "\\": "vim::VisualCommand",
      "u": "vim::ConvertToLowerCase",
