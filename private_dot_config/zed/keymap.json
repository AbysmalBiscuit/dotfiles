  // General normal mode
  {
    "context": "vim_mode == normal && !Terminal",
    "bindings": {},
  },
  {
    "context": "vim_mode == normal",
    "bindings": {
      "ctrl-/": "terminal_panel::ToggleFocus",
      "ctrl-[": "editor::Cancel",
      "escape": "editor::Cancel",
      ":": "command_palette::Toggle",
      // "ctrl-;": "command_palette::Toggle",
      "ctrl-,": ["workspace::SendKeystrokes", "A ,"],
      "ctrl-;": ["workspace::SendKeystrokes", "A ;"],
      "ctrl-shift-,": "zed::OpenSettings",
      "\\": "command_palette::Toggle",
