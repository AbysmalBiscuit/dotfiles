      "g s r": ["vim::PushChangeSurrounds", {}],
      "g s d": "vim::PushDeleteSurrounds",
      "g s a": "vim::PushAddSurrounds",
      "c": "vim::PushChange",
      "shift-c": "vim::ChangeToEndOfLine",
      "d": "vim::PushDelete",
      "shift-d": "vim::DeleteToEndOfLine",
      "shift-j": "vim::JoinLines",
