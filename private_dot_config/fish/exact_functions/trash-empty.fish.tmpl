# {{- if .tool.trash_cli -}}
# chezmoi:template:left-delimiter="# {{" right-delimiter="}}"
function trash-empty --wraps='trash-empty' --description 'Sets TRASHDIR automatically based on current realpath'
    set -l trashdir (__get_trash_dir)
    command trash-empty --trash-dir $trashdir $argv
end
# {{- end -}}
